@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Đăng nhập - Hệ thống Thuyết Minh Vĩnh Khánh</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons/font/bootstrap-icons.css" rel="stylesheet" />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;600;700&display=swap" rel="stylesheet" />
    <style>
        * { font-family: 'Inter', sans-serif; }
        body {
            min-height: 100vh;
            display: flex;
            align-items: center;
            justify-content: center;
            background: linear-gradient(135deg, #0f2027, #203a43, #2c5364);
            position: relative;
            overflow: hidden;
        }
        body::before {
            content: '';
            position: fixed;
            width: 600px; height: 600px;
            background: radial-gradient(circle, rgba(99,179,237,0.15), transparent);
            top: -100px; right: -100px;
            border-radius: 50%;
        }
        body::after {
            content: '';
            position: fixed;
            width: 400px; height: 400px;
            background: radial-gradient(circle, rgba(237,137,54,0.1), transparent);
            bottom: -80px; left: -80px;
            border-radius: 50%;
        }
        .login-card {
            background: rgba(255,255,255,0.05);
            backdrop-filter: blur(20px);
            border: 1px solid rgba(255,255,255,0.15);
            border-radius: 20px;
            padding: 2.5rem;
            width: 100%;
            max-width: 420px;
            box-shadow: 0 25px 50px rgba(0,0,0,0.4);
            position: relative;
            z-index: 1;
        }
        .logo-icon {
            width: 70px; height: 70px;
            background: linear-gradient(135deg, #f6ad55, #ed8936);
            border-radius: 18px;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1.8rem;
            margin: 0 auto 1.5rem;
            box-shadow: 0 10px 25px rgba(237,137,54,0.4);
        }
        .form-control {
            background: rgba(255,255,255,0.08);
            border: 1px solid rgba(255,255,255,0.2);
            color: white;
            border-radius: 10px;
            padding: 0.75rem 1rem;
            transition: all 0.3s;
        }
        .form-control:focus {
            background: rgba(255,255,255,0.12);
            border-color: #f6ad55;
            color: white;
            box-shadow: 0 0 0 0.2rem rgba(246,173,85,0.25);
        }
        .form-control::placeholder { color: rgba(255,255,255,0.4); }
        label { color: rgba(255,255,255,0.8); font-weight: 500; font-size: 0.9rem; }
        .btn-login {
            background: linear-gradient(135deg, #f6ad55, #ed8936);
            border: none;
            border-radius: 10px;
            padding: 0.75rem;
            font-weight: 600;
            font-size: 1rem;
            color: white;
            transition: all 0.3s;
            box-shadow: 0 5px 15px rgba(237,137,54,0.4);
        }
        .btn-login:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(237,137,54,0.5);
            color: white;
        }
        .input-icon { position: relative; }
        .input-icon .bi { position: absolute; left: 1rem; top: 50%; transform: translateY(-50%); color: rgba(255,255,255,0.4); z-index: 1; }
        .input-icon .form-control { padding-left: 2.5rem; }
        .divider { border-color: rgba(255,255,255,0.15); }
        .register-link a { color: #f6ad55; text-decoration: none; font-weight: 600; }
        .register-link a:hover { text-decoration: underline; }
        .register-link { color: rgba(255,255,255,0.6); font-size: 0.9rem; text-align: center; }
    </style>
</head>
<body>
<div class="login-card">
    <div class="logo-icon">🎙</div>
    <h4 class="text-white text-center mb-1 fw-bold">Vĩnh Khánh</h4>
    <p class="text-center mb-4" style="color:rgba(255,255,255,0.5); font-size:0.85rem;">Hệ thống thuyết minh tự động</p>

    @if (ViewBag.Error != null)
    {
        <div class="alert alert-danger rounded-3 py-2 px-3 mb-3" style="font-size:0.9rem;">
            <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.Error
        </div>
    }

    <form method="post" action="/Auth/Login">
        <div class="mb-3">
            <label class="mb-1">Tên đăng nhập</label>
            <div class="input-icon">
                <i class="bi bi-person"></i>
                <input id="username" name="username" type="text" class="form-control" placeholder="Nhập tên đăng nhập" required />
            </div>
        </div>
        <div class="mb-4">
            <label class="mb-1">Mật khẩu</label>
            <div class="input-icon">
                <i class="bi bi-lock"></i>
                <input id="password" name="password" type="password" class="form-control" placeholder="Nhập mật khẩu" required />
            </div>
        </div>
        <button type="submit" class="btn btn-login w-100">
            <i class="bi bi-box-arrow-in-right me-2"></i>Đăng nhập
        </button>
    </form>

    <hr class="divider my-4" />
    <p class="register-link">
        Muốn đăng ký quản lý địa điểm? <a href="/Auth/Register">Đăng ký tại đây</a>
    </p>
</div>
</body>
</html>
