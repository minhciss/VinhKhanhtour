@model VinhKhanhadmin.Models.StatsViewModel

@{
    var weekLabels = string.Join(",", Model.WeekdayStats.Select(d => $"\"{d.Day}\""));
    var weekCounts = string.Join(",", Model.WeekdayStats.Select(d => d.Count));
    var poiLabels  = string.Join(",", Model.TopPois.Select(p => $"\"{p.PoiName}\""));
    var poiCounts  = string.Join(",", Model.TopPois.Select(p => p.Count));
    var dayLabels  = string.Join(",", Model.Last7Days.Select(d => $"\"{d.Date}\""));
    var dayCounts  = string.Join(",", Model.Last7Days.Select(d => d.Count));
    int maxWeek    = Model.WeekdayStats.Any() ? Model.WeekdayStats.Max(d => d.Count) : 0;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show" role="alert">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ══════════════════════════════════════════
     HEADER
══════════════════════════════════════════ -->
<div class="d-flex align-items-center mb-4 gap-3">
    <div class="rounded-circle d-flex align-items-center justify-content-center"
         style="width:52px;height:52px;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
        <i class="bi bi-bar-chart-line-fill text-white fs-4"></i>
    </div>
    <div>
        <h4 class="mb-0 fw-bold text-white">Thống kê hoạt động du khách</h4>
        <small class="text-white-50">Dữ liệu tổng hợp · Không lưu thông tin cá nhân</small>
    </div>
    <span class="ms-auto badge text-bg-secondary px-3 py-2">
        <i class="bi bi-clock me-1"></i>Cập nhật theo thời gian thực
    </span>
</div>

<!-- ══════════════════════════════════════════
     KPI CARDS
══════════════════════════════════════════ -->
<div class="row g-3 mb-4">

    <!-- Card 1: Tổng lượt nghe -->
    <div class="col-6 col-xl-3">
        <div class="card border-0 text-white h-100 shadow kpi-card" style="background:linear-gradient(135deg,#6366f1,#4f46e5);">
            <div class="card-body d-flex flex-column justify-content-between p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75 fw-semibold text-uppercase ls-1">Tổng lượt nghe</p>
                        <h2 class="fw-bold mb-0 display-6">@Model.TotalUnlocks</h2>
                    </div>
                    <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.15);">
                        <i class="bi bi-headphones fs-3"></i>
                    </div>
                </div>
                <p class="mb-0 mt-3 small opacity-75"><i class="bi bi-graph-up me-1"></i>Tổng số lần mở khóa audio</p>
            </div>
        </div>
    </div>

    <!-- Card 2: Thiết bị đang hoạt động -->
    <div class="col-6 col-xl-3">
        <div class="card border-0 text-white h-100 shadow kpi-card" style="background:linear-gradient(135deg,#10b981,#059669);">
            <div class="card-body d-flex flex-column justify-content-between p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75 fw-semibold text-uppercase ls-1">Đang hoạt động</p>
                        <h2 class="fw-bold mb-0 display-6">@Model.ActiveDevices</h2>
                    </div>
                    <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.15);">
                        <i class="bi bi-phone fs-3"></i>
                    </div>
                </div>
                <p class="mb-0 mt-3 small opacity-75"><i class="bi bi-wifi me-1"></i>Phiên còn hạn hiện tại</p>
            </div>
        </div>
    </div>

    <!-- Card 3: Ngày đông nhất -->
    <div class="col-6 col-xl-3">
        <div class="card border-0 text-white h-100 shadow kpi-card" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
            <div class="card-body d-flex flex-column justify-content-between p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75 fw-semibold text-uppercase ls-1">Ngày đông nhất</p>
                        <h2 class="fw-bold mb-0 display-6">@Model.BusiestDay</h2>
                    </div>
                    <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.15);">
                        <i class="bi bi-trophy fs-3"></i>
                    </div>
                </div>
                <p class="mb-0 mt-3 small opacity-75">
                    <i class="bi bi-people me-1"></i>@Model.BusiestCount lượt (30 ngày gần đây)
                </p>
            </div>
        </div>
    </div>

    <!-- Card 4: Top POI -->
    <div class="col-6 col-xl-3">
        <div class="card border-0 text-white h-100 shadow kpi-card" style="background:linear-gradient(135deg,#ec4899,#db2777);">
            <div class="card-body d-flex flex-column justify-content-between p-4">
                <div class="d-flex justify-content-between align-items-start">
                    <div>
                        <p class="mb-1 small opacity-75 fw-semibold text-uppercase ls-1">Điểm nổi bật nhất</p>
                        <h5 class="fw-bold mb-0 mt-1" style="font-size:1.1rem;line-height:1.3;">
                            @(Model.TopPois.FirstOrDefault()?.PoiName ?? "—")
                        </h5>
                    </div>
                    <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.15);">
                        <i class="bi bi-geo-alt-fill fs-3"></i>
                    </div>
                </div>
                <p class="mb-0 mt-3 small opacity-75">
                    <i class="bi bi-star-fill me-1"></i>@(Model.TopPois.FirstOrDefault()?.Count ?? 0) lượt nghe
                </p>
            </div>
        </div>
    </div>

</div>

<!-- ══════════════════════════════════════════
     CHARTS ROW 1: Weekly + 7-day trend
══════════════════════════════════════════ -->
<div class="row g-3 mb-4">

    <!-- Biểu đồ theo ngày trong tuần -->
    <div class="col-12 col-xl-7">
        <div class="card border-0 shadow-sm h-100" style="background:rgba(30,30,50,.85);backdrop-filter:blur(10px);">
            <div class="card-header border-0 pb-0 pt-4 px-4" style="background:transparent;">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill" style="background:#6366f1;padding:.45rem .75rem;">
                        <i class="bi bi-calendar-week me-1"></i>Theo ngày trong tuần
                    </span>
                    <small class="text-white-50">(30 ngày gần đây)</small>
                </div>
                <h6 class="text-white mt-2 mb-0">Ngày nào đông khách nhất?</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <canvas id="weekdayChart" height="220"></canvas>
            </div>
        </div>
    </div>

    <!-- Trend 7 ngày gần đây -->
    <div class="col-12 col-xl-5">
        <div class="card border-0 shadow-sm h-100" style="background:rgba(30,30,50,.85);backdrop-filter:blur(10px);">
            <div class="card-header border-0 pb-0 pt-4 px-4" style="background:transparent;">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill" style="background:#10b981;padding:.45rem .75rem;">
                        <i class="bi bi-graph-up me-1"></i>7 ngày gần đây
                    </span>
                </div>
                <h6 class="text-white mt-2 mb-0">Xu hướng hoạt động</h6>
            </div>
            <div class="card-body px-4 pb-4">
                <canvas id="trendChart" height="220"></canvas>
            </div>
        </div>
    </div>

</div>

<!-- ══════════════════════════════════════════
     CHARTS ROW 2: Top POI + Weekday table
══════════════════════════════════════════ -->
<div class="row g-3">

    <!-- Biểu đồ Top POI -->
    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm" style="background:rgba(30,30,50,.85);backdrop-filter:blur(10px);">
            <div class="card-header border-0 pb-0 pt-4 px-4" style="background:transparent;">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill" style="background:#ec4899;padding:.45rem .75rem;">
                        <i class="bi bi-geo-alt me-1"></i>Top POI được nghe nhiều nhất
                    </span>
                </div>
            </div>
            <div class="card-body px-4 pb-4">
                @if (Model.TopPois.Any())
                {
                    <canvas id="poiChart" height="220"></canvas>
                }
                else
                {
                    <div class="text-center text-white-50 py-5">
                        <i class="bi bi-inbox fs-1 d-block mb-2"></i>
                        Chưa có dữ liệu POI nào
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Bảng xếp hạng ngày trong tuần -->
    <div class="col-12 col-xl-6">
        <div class="card border-0 shadow-sm" style="background:rgba(30,30,50,.85);backdrop-filter:blur(10px);">
            <div class="card-header border-0 pb-0 pt-4 px-4" style="background:transparent;">
                <div class="d-flex align-items-center gap-2">
                    <span class="badge rounded-pill" style="background:#f59e0b;padding:.45rem .75rem;">
                        <i class="bi bi-table me-1"></i>Xếp hạng ngày trong tuần
                    </span>
                </div>
            </div>
            <div class="card-body px-4 pb-4">
                <div class="table-responsive">
                    <table class="table table-sm align-middle mb-0" style="color:#e2e8f0;">
                        <thead>
                            <tr style="border-color:rgba(255,255,255,.1);">
                                <th class="text-white-50 fw-normal">#</th>
                                <th class="text-white-50 fw-normal">Ngày</th>
                                <th class="text-white-50 fw-normal">Lượt nghe</th>
                                <th class="text-white-50 fw-normal">Tỉ lệ</th>
                            </tr>
                        </thead>
                        <tbody>
                            @{
                                var sortedDays = Model.WeekdayStats
                                    .OrderByDescending(d => d.Count)
                                    .ToList();
                                int rank = 1;
                            }
                            @foreach (var day in sortedDays)
                            {
                                var pct = maxWeek > 0 ? (int)Math.Round(day.Count * 100.0 / maxWeek) : 0;
                                var isBusiest = day.Day == Model.BusiestDay;
                                <tr style="border-color:rgba(255,255,255,.07);">
                                    <td>
                                        @if (rank == 1)
                                        {
                                            <span class="badge" style="background:#f59e0b;">🏆</span>
                                        }
                                        else if (rank == 2)
                                        {
                                            <span class="text-white-50">②</span>
                                        }
                                        else if (rank == 3)
                                        {
                                            <span class="text-white-50">③</span>
                                        }
                                        else
                                        {
                                            <span class="text-white-50 small">@rank</span>
                                        }
                                    </td>
                                    <td>
                                        <span class="fw-semibold @(isBusiest ? "text-warning" : "text-white")">
                                            @day.Day
                                        </span>
                                    </td>
                                    <td>
                                        <span class="fw-bold @(isBusiest ? "text-warning" : "")">@day.Count</span>
                                    </td>
                                    <td style="min-width:120px;">
                                        <div class="progress" style="height:8px;background:rgba(255,255,255,.1);border-radius:99px;">
                                            <div class="progress-bar @(isBusiest ? "" : "bg-secondary")"
                                                 role="progressbar"
                                                 style="width:@pct%;border-radius:99px;@(isBusiest ? "background:linear-gradient(90deg,#f59e0b,#fbbf24);" : "")">
                                            </div>
                                        </div>
                                    </td>
                                </tr>
                                rank++;
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>

</div>

<!-- ══════════════════════════════════════════
     STYLES
══════════════════════════════════════════ -->
<style>
    .kpi-card {
        border-radius: 16px !important;
        transition: transform .2s, box-shadow .2s;
    }
    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0,0,0,.35) !important;
    }
    .kpi-icon-wrap {
        width: 52px;
        height: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .ls-1 { letter-spacing: .05em; }
</style>

<!-- ══════════════════════════════════════════
     CHART.JS
══════════════════════════════════════════ -->
@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    Chart.defaults.color = 'rgba(226,232,240,.75)';
    Chart.defaults.borderColor = 'rgba(255,255,255,.07)';

    const weekColors = [
        @foreach (var d in Model.WeekdayStats)
        {
            @(d.Day == Model.BusiestDay
                ? "'rgba(245,158,11,.9)'"
                : "'rgba(99,102,241,.65)'")<text>,</text>
        }
    ];

    // ── Biểu đồ theo ngày trong tuần ──
    new Chart(document.getElementById('weekdayChart'), {
        type: 'bar',
        data: {
            labels: [@Html.Raw(weekLabels)],
            datasets: [{
                label: 'Lượt nghe',
                data: [@weekCounts],
                backgroundColor: weekColors,
                borderRadius: 8,
                borderSkipped: false,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: {
                    callbacks: {
                        label: ctx => ` ${ctx.parsed.y} lượt nghe`
                    }
                }
            },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { precision: 0 },
                    grid: { color: 'rgba(255,255,255,.07)' }
                },
                x: {
                    grid: { display: false }
                }
            }
        }
    });

    // ── Biểu đồ trend 7 ngày ──
    new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
            labels: [@Html.Raw(dayLabels)],
            datasets: [{
                label: 'Lượt nghe',
                data: [@dayCounts],
                borderColor: '#10b981',
                backgroundColor: 'rgba(16,185,129,.15)',
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#10b981',
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: {
                    beginAtZero: true,
                    ticks: { precision: 0 },
                    grid: { color: 'rgba(255,255,255,.07)' }
                },
                x: { grid: { display: false } }
            }
        }
    });

    // ── Biểu đồ top POI ──
    @if (Model.TopPois.Any())
    {
        <text>
    new Chart(document.getElementById('poiChart'), {
        type: 'bar',
        data: {
            labels: [@Html.Raw(poiLabels)],
            datasets: [{
                label: 'Lượt nghe',
                data: [@poiCounts],
                backgroundColor: [
                    'rgba(236,72,153,.8)',
                    'rgba(99,102,241,.8)',
                    'rgba(16,185,129,.8)',
                    'rgba(245,158,11,.8)',
                    'rgba(239,68,68,.8)'
                ],
                borderRadius: 8,
                borderSkipped: false,
                borderWidth: 0
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: {
                    beginAtZero: true,
                    ticks: { precision: 0 },
                    grid: { color: 'rgba(255,255,255,.07)' }
                },
                y: { grid: { display: false } }
            }
        }
    });
        </text>
    }
</script>
}
