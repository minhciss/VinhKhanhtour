@model VinhKhanhadmin.Models.StatsViewModel
@using System.Text.Json

@{
    // ── Serialize data sang JSON để inject an toàn vào JavaScript (tránh lỗi encoding) ──
    var weekJson  = JsonSerializer.Serialize(Model.WeekdayStats.Select(d => new { label = d.Day,   value = d.Count }).ToList());
    var trendJson = JsonSerializer.Serialize(Model.Last7Days.Select(d => new { label = d.Date,  value = d.Count }).ToList());
    var poiJson   = JsonSerializer.Serialize(Model.TopPois.Select(p => new { label = p.PoiName, value = p.Count }).ToList());
    var hourJson  = JsonSerializer.Serialize(Model.HourlyStats.Select(h => new { label = h.Hour, value = h.Count }).ToList());
    var busiestDayJs  = JsonSerializer.Serialize(Model.BusiestDay);
    var busiestHourJs = JsonSerializer.Serialize(Model.BusiestHour);
    int maxWeek = Model.WeekdayStats.Any() ? Model.WeekdayStats.Max(d => d.Count) : 1;
}

@if (TempData["Error"] != null)
{
    <div class="alert alert-warning alert-dismissible fade show">
        <i class="bi bi-exclamation-triangle me-2"></i>@TempData["Error"]
        <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
    </div>
}

<!-- ══ HEADER ══ -->
<div class="d-flex align-items-center mb-4 gap-3">
    <div class="kpi-icon-wrap" style="width:54px;height:54px;background:linear-gradient(135deg,#6366f1,#8b5cf6);">
        <i class="bi bi-bar-chart-line-fill text-white fs-4"></i>
    </div>
    <div>
        <h4 class="mb-0 fw-bold text-white">Thống kê hoạt động du khách</h4>
        <small class="text-white-50">Dữ liệu tổng hợp · Không lưu thông tin cá nhân · UTC+7</small>
    </div>
    <div class="ms-auto d-flex align-items-center gap-2">
        <button class="btn btn-sm btn-outline-light" onclick="location.reload()">
            <i class="bi bi-arrow-clockwise"></i> Làm mới
        </button>
    </div>
</div>

<!-- ══ KPI CARDS (5 cards) ══ -->
<div class="row g-3 mb-4">

    <div class="col-6 col-xl">
        <div class="kpi-card text-white h-100" style="background:linear-gradient(135deg,#6366f1,#4f46e5);">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="kpi-label">Tổng lượt nghe</p>
                    <h2 class="kpi-value">@Model.TotalUnlocks</h2>
                </div>
                <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.18);">
                    <i class="bi bi-headphones fs-3"></i>
                </div>
            </div>
            <p class="kpi-sub"><i class="bi bi-graph-up me-1"></i>Tổng số lần mở khóa audio</p>
        </div>
    </div>

    <div class="col-6 col-xl">
        <div class="kpi-card text-white h-100" style="background:linear-gradient(135deg,#10b981,#059669);">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="kpi-label">Đang hoạt động</p>
                    <h2 class="kpi-value">@Model.ActiveDevices</h2>
                </div>
                <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.18);">
                    <i class="bi bi-phone fs-3"></i>
                </div>
            </div>
            <p class="kpi-sub"><i class="bi bi-wifi me-1"></i>Phiên còn hạn (24h)</p>
        </div>
    </div>

    <div class="col-6 col-xl">
        <div class="kpi-card text-white h-100" style="background:linear-gradient(135deg,#f59e0b,#d97706);">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="kpi-label">Ngày đông nhất</p>
                    <h2 class="kpi-value" style="font-size:1.8rem;">@Model.BusiestDay</h2>
                </div>
                <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.18);">
                    <i class="bi bi-trophy fs-3"></i>
                </div>
            </div>
            <p class="kpi-sub"><i class="bi bi-people me-1"></i>@Model.BusiestCount lượt (30 ngày gần)</p>
        </div>
    </div>

    <div class="col-6 col-xl">
        <div class="kpi-card text-white h-100" style="background:linear-gradient(135deg,#06b6d4,#0891b2);">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="kpi-label">Giờ cao điểm</p>
                    <h2 class="kpi-value" style="font-size:1.8rem;">@Model.BusiestHour</h2>
                </div>
                <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.18);">
                    <i class="bi bi-clock-fill fs-3"></i>
                </div>
            </div>
            <p class="kpi-sub"><i class="bi bi-lightning me-1"></i>@Model.BusiestHourCount lượt nghe</p>
        </div>
    </div>

    <div class="col-6 col-xl">
        <div class="kpi-card text-white h-100" style="background:linear-gradient(135deg,#ec4899,#db2777);">
            <div class="d-flex justify-content-between align-items-start mb-3">
                <div>
                    <p class="kpi-label">Điểm nổi bật nhất</p>
                    <h5 style="font-size:1rem;line-height:1.4;margin-top:.4rem;">
                        @(Model.TopPois.FirstOrDefault()?.PoiName ?? "—")
                    </h5>
                </div>
                <div class="kpi-icon-wrap" style="background:rgba(255,255,255,.18);">
                    <i class="bi bi-geo-alt-fill fs-3"></i>
                </div>
            </div>
            <p class="kpi-sub"><i class="bi bi-star-fill me-1"></i>@(Model.TopPois.FirstOrDefault()?.Count ?? 0) lượt nghe</p>
        </div>
    </div>

</div>

<!-- ══ ACTIVE SESSIONS TABLE ══ -->
@if (Model.ActiveSessions.Any())
{
    <div class="dark-card mb-4">
        <div class="dark-card-header d-flex align-items-center gap-2">
            <span class="badge rounded-pill px-3 py-2" style="background:#10b981;">
                <i class="bi bi-phone-fill me-1"></i>Thiết bị đang hoạt động
            </span>
            <span class="badge bg-success ms-1">@Model.ActiveDevices thiết bị</span>
            <span class="ms-auto text-white-50 small">
                <i class="bi bi-info-circle me-1"></i>Cập nhật theo heartbeat mỗi 15 giây · Tự động ẩn sau 30 giây không ping
            </span>
        </div>
        <div class="table-responsive">
            <table class="table table-sm mb-0" style="color:#e2e8f0;">
                <thead>
                    <tr class="stat-thead">
                        <th>#</th>
                        <th><i class="bi bi-phone me-1"></i>Device ID (ẩn danh)</th>
                        <th>Trạng thái</th>
                        <th>Hoạt động lần cuối</th>
                    </tr>
                </thead>
                <tbody>
                    @{ int sIdx = 1; }
                    @foreach (var s in Model.ActiveSessions)
                    {
                        <tr class="stat-row">
                            <td class="text-white-50 small">@sIdx</td>
                            <td>
                                <code class="text-success" style="font-size:.85rem;">@s.SessionId</code>
                            </td>
                            <td>
                                <span class="badge" style="background:#10b981;">
                                    <i class="bi bi-circle-fill me-1" style="font-size:.5rem;"></i>Online
                                </span>
                            </td>
                            <td class="text-white-50 small">
                                <i class="bi bi-clock me-1"></i>@s.LastSeen
                                <span class="ms-1 text-warning small">(@s.ExpiresAt)</span>
                            </td>
                        </tr>
                        sIdx++;
                    }
                </tbody>
            </table>
        </div>
    </div>
}

<!-- ══ CHARTS ROW 1: Ngày trong tuần + Xu hướng 7 ngày ══ -->
<div class="row g-3 mb-4">
    <div class="col-12 col-xl-7">
        <div class="dark-card h-100">
            <div class="dark-card-header">
                <span class="badge rounded-pill px-3 py-2" style="background:#6366f1;">
                    <i class="bi bi-calendar-week me-1"></i>Theo ngày trong tuần
                </span>
                <small class="text-white-50 ms-2">(30 ngày gần đây)</small>
                <h6 class="text-white mt-2 mb-0">Ngày nào đông khách nhất?</h6>
            </div>
            <canvas id="weekdayChart" height="200"></canvas>
        </div>
    </div>
    <div class="col-12 col-xl-5">
        <div class="dark-card h-100">
            <div class="dark-card-header">
                <span class="badge rounded-pill px-3 py-2" style="background:#10b981;">
                    <i class="bi bi-graph-up me-1"></i>7 ngày gần đây
                </span>
                <h6 class="text-white mt-2 mb-0">Xu hướng hoạt động</h6>
            </div>
            <canvas id="trendChart" height="200"></canvas>
        </div>
    </div>
</div>

<!-- ══ CHARTS ROW 2: Giờ cao điểm (full width) ══ -->
<div class="dark-card mb-4">
    <div class="dark-card-header">
        <span class="badge rounded-pill px-3 py-2" style="background:#06b6d4;">
            <i class="bi bi-clock me-1"></i>Theo giờ trong ngày
        </span>
        <small class="text-white-50 ms-2">(30 ngày gần đây)</small>
        <h6 class="text-white mt-2 mb-0">
            Khung giờ nào được nghe nhiều nhất?
            <span class="badge ms-2" style="background:#f59e0b;font-size:.75rem;">⚡ Cao điểm: @Model.BusiestHour</span>
        </h6>
    </div>
    <canvas id="hourlyChart" height="120"></canvas>
</div>

<!-- ══ CHARTS ROW 3: Top POI + Bảng xếp hạng ══ -->
<div class="row g-3">
    <div class="col-12 col-xl-6">
        <div class="dark-card h-100">
            <div class="dark-card-header">
                <span class="badge rounded-pill px-3 py-2" style="background:#ec4899;">
                    <i class="bi bi-geo-alt me-1"></i>Top POI được nghe nhiều nhất
                </span>
            </div>
            @if (Model.TopPois.Any())
            {
                <canvas id="poiChart" height="220"></canvas>
            }
            else
            {
                <div class="text-center text-white-50 py-5">
                    <i class="bi bi-inbox fs-1 d-block mb-2 opacity-50"></i>Chưa có dữ liệu
                </div>
            }
        </div>
    </div>

    <div class="col-12 col-xl-6">
        <div class="dark-card h-100">
            <div class="dark-card-header">
                <span class="badge rounded-pill px-3 py-2" style="background:#f59e0b;">
                    <i class="bi bi-table me-1"></i>Xếp hạng ngày trong tuần
                </span>
            </div>
            <div class="table-responsive">
                <table class="table table-sm mb-0" style="color:#e2e8f0;">
                    <thead>
                        <tr class="stat-thead">
                            <th style="width:40px;">#</th>
                            <th>Ngày</th>
                            <th style="width:80px;">Lượt</th>
                            <th>Tỉ lệ</th>
                        </tr>
                    </thead>
                    <tbody>
                        @{
                            var sortedDays = Model.WeekdayStats.OrderByDescending(d => d.Count).ToList();
                            int dRank = 1;
                        }
                        @foreach (var day in sortedDays)
                        {
                            var pct = (int)Math.Round(day.Count * 100.0 / maxWeek);
                            bool top = dRank == 1;
                            <tr class="stat-row">
                                <td>
                                    @if (dRank == 1) { <span>🏆</span> }
                                    else if (dRank == 2) { <span class="text-white-50">②</span> }
                                    else if (dRank == 3) { <span class="text-white-50">③</span> }
                                    else { <span class="text-white-50 small">@dRank</span> }
                                </td>
                                <td>
                                    <strong class="@(top ? "text-warning" : "text-light")">@day.Day</strong>
                                </td>
                                <td>
                                    <span class="fw-bold @(top ? "text-warning" : "text-light")">@day.Count</span>
                                </td>
                                <td>
                                    <div class="progress" style="height:8px;background:rgba(255,255,255,.1);border-radius:99px;">
                                        <div class="progress-bar @(top ? "" : "bg-secondary")"
                                             style="width:@pct%;border-radius:99px;@(top ? "background:linear-gradient(90deg,#f59e0b,#fbbf24);" : "")">
                                        </div>
                                    </div>
                                </td>
                            </tr>
                            dRank++;
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>

<!-- ══ STYLES ══ -->
<style>
    .kpi-card {
        padding: 1.25rem 1.5rem;
        border-radius: 16px;
        border: none;
        transition: transform .2s, box-shadow .2s;
        box-shadow: 0 4px 16px rgba(0,0,0,.25);
    }
    .kpi-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 12px 30px rgba(0,0,0,.35);
    }
    .kpi-label {
        margin-bottom: .25rem;
        font-size: .72rem;
        font-weight: 600;
        letter-spacing: .06em;
        text-transform: uppercase;
        opacity: .8;
    }
    .kpi-value {
        font-size: 2.2rem;
        font-weight: 700;
        margin: 0;
        line-height: 1;
    }
    .kpi-sub {
        margin: 0;
        font-size: .78rem;
        opacity: .75;
    }
    .kpi-icon-wrap {
        width: 52px;
        height: 52px;
        min-width: 52px;
        border-radius: 14px;
        display: flex;
        align-items: center;
        justify-content: center;
    }
    .dark-card {
        background: rgba(20, 20, 40, .9);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,.08);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: 0 4px 20px rgba(0,0,0,.3);
    }
    .dark-card-header {
        margin-bottom: 1rem;
    }
    .stat-thead th {
        color: rgba(255,255,255,.45);
        font-weight: 500;
        font-size: .78rem;
        border-color: rgba(255,255,255,.08);
        padding: .5rem .75rem;
    }
    .stat-row td {
        border-color: rgba(255,255,255,.06);
        padding: .6rem .75rem;
        vertical-align: middle;
    }
</style>

@section Scripts {
<script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
<script>
    // ── Dữ liệu từ server (JSON serialized, an toàn với Unicode) ──
    const WEEK  = @Html.Raw(weekJson);
    const TREND = @Html.Raw(trendJson);
    const POI   = @Html.Raw(poiJson);
    const HOUR  = @Html.Raw(hourJson);
    const BUSIEST_DAY  = @Html.Raw(busiestDayJs);
    const BUSIEST_HOUR = @Html.Raw(busiestHourJs);

    // ── Cài đặt Chart.js mặc định ──
    Chart.defaults.color           = 'rgba(226,232,240,.8)';
    Chart.defaults.borderColor     = 'rgba(255,255,255,.07)';
    Chart.defaults.font.family     = 'system-ui, sans-serif';

    // ── 1. Biểu đồ cột ngày trong tuần ──
    new Chart(document.getElementById('weekdayChart'), {
        type: 'bar',
        data: {
            labels: WEEK.map(d => d.label),
            datasets: [{
                label: 'Lượt nghe',
                data:  WEEK.map(d => d.value),
                backgroundColor: WEEK.map(d =>
                    d.label === BUSIEST_DAY ? 'rgba(245,158,11,.9)' : 'rgba(99,102,241,.65)'
                ),
                borderRadius: 8,
                borderSkipped: false,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => ` ${ctx.parsed.y} lượt` } }
            },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(255,255,255,.06)' } },
                x: { grid: { display: false } }
            }
        }
    });

    // ── 2. Line chart xu hướng 7 ngày ──
    new Chart(document.getElementById('trendChart'), {
        type: 'line',
        data: {
            labels: TREND.map(d => d.label),
            datasets: [{
                label: 'Lượt nghe',
                data:  TREND.map(d => d.value),
                borderColor: '#10b981',
                backgroundColor: 'rgba(16,185,129,.15)',
                tension: 0.4,
                fill: true,
                pointBackgroundColor: '#10b981',
                pointRadius: 5,
                pointHoverRadius: 7
            }]
        },
        options: {
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(255,255,255,.06)' } },
                x: { grid: { display: false } }
            }
        }
    });

    // ── 3. Biểu đồ cột theo giờ (24h) ──
    new Chart(document.getElementById('hourlyChart'), {
        type: 'bar',
        data: {
            labels: HOUR.map(d => d.label),
            datasets: [{
                label: 'Lượt nghe',
                data:  HOUR.map(d => d.value),
                backgroundColor: HOUR.map(d =>
                    d.label === BUSIEST_HOUR ? 'rgba(245,158,11,.9)' : 'rgba(6,182,212,.55)'
                ),
                borderRadius: 6,
                borderSkipped: false,
                borderWidth: 0
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: { display: false },
                tooltip: { callbacks: { label: ctx => ` ${ctx.parsed.y} lượt` } }
            },
            scales: {
                y: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(255,255,255,.06)' } },
                x: { grid: { display: false }, ticks: { maxRotation: 45 } }
            }
        }
    });

    // ── 4. Horizontal bar Top POI ──
    @if (Model.TopPois.Any())
    {
        <text>
    new Chart(document.getElementById('poiChart'), {
        type: 'bar',
        data: {
            labels: POI.map(d => d.label),
            datasets: [{
                label: 'Lượt nghe',
                data:  POI.map(d => d.value),
                backgroundColor: [
                    'rgba(236,72,153,.85)',
                    'rgba(99,102,241,.85)',
                    'rgba(16,185,129,.85)',
                    'rgba(245,158,11,.85)',
                    'rgba(6,182,212,.85)'
                ],
                borderRadius: 8,
                borderSkipped: false,
                borderWidth: 0
            }]
        },
        options: {
            indexAxis: 'y',
            responsive: true,
            plugins: { legend: { display: false } },
            scales: {
                x: { beginAtZero: true, ticks: { precision: 0 }, grid: { color: 'rgba(255,255,255,.06)' } },
                y: { grid: { display: false } }
            }
        }
    });
        </text>
    }
</script>
}
