@model List<Poi>

<div class="card shadow-sm bg-white text-dark mb-4">
    <div class="card-header bg-dark text-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-geo-alt-fill me-2"></i>Danh sách POI (Điểm đến)</h5>
        <a href="/Admin/Create" class="btn btn-primary btn-sm">
            ➕ Thêm mới
        </a>
    </div>

    <div class="card-body bg-light border-bottom p-3 d-flex gap-2">
        <a href="/Admin/Index" class="btn btn-sm @(ViewBag.CurrentStatus == "all" ? "btn-primary" : "btn-outline-primary")">Tất cả</a>
        <a href="/Admin/Index?status=Pending" class="btn btn-sm @(ViewBag.CurrentStatus == "Pending" ? "btn-warning" : "btn-outline-warning")">
            Chờ duyệt
            @if (ViewBag.PendingCount > 0)
            {
                <span class="badge bg-danger ms-1">@ViewBag.PendingCount</span>
            }
        </a>
        <a href="/Admin/Index?status=Approved" class="btn btn-sm @(ViewBag.CurrentStatus == "Approved" ? "btn-success" : "btn-outline-success")">Đã duyệt</a>
    </div>

    <div class="card-body p-0 table-responsive">
        <table class="table table-hover mb-0 align-middle">
            <thead class="table-light">
                <tr>
                    <th>Tên</th>
                    <th>Địa chỉ</th>
                    <th>Trạng thái & Hiển thị</th>
                    <th>QR</th>
                    <th style="width:250px;">Hành động</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td class="fw-bold text-primary">@item.Name</td>
                        <td>@item.Address</td>

                        <td>
                            <div class="d-flex flex-column gap-1 align-items-start">
                                @if (item.Status == "Pending")
                                {
                                    <span class="badge bg-warning text-dark"><i class="bi bi-hourglass-split me-1"></i>Chờ duyệt</span>
                                }
                                else if (item.Status == "Rejected")
                                {
                                    <span class="badge bg-danger"><i class="bi bi-x-circle me-1"></i>Từ chối</span>
                                }
                                else
                                {
                                    <span class="badge bg-success"><i class="bi bi-check-circle me-1"></i>Đã duyệt</span>
                                }

                                @if (item.Status == "Approved")
                                {
                                    if (item.IsActive)
                                    {
                                        <span class="badge bg-info text-dark">Đang hiển thị Web/App</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-secondary">Tạm Tắt</span>
                                    }
                                }
                            </div>
                        </td>

                        <td>
                            <img src="@ViewBag.AdminBaseUrl/Poi/Qr/@item.Id" width="70" class="border rounded shadow-sm" />
                        </td>

                        <td>
                            @if (item.Status == "Pending")
                            {
                                <a href="/Admin/ApprovePoi/@item.Id" class="btn btn-success btn-sm me-1"><i class="bi bi-check-lg"></i> Duyệt</a>
                                <a href="/Admin/RejectPoi/@item.Id" class="btn btn-danger btn-sm me-1" onclick="return confirm('Từ chối POI này?')"><i class="bi bi-x-lg"></i> Loại bỏ</a>
                                <a href="/Admin/Edit/@item.Id" class="btn btn-outline-primary btn-sm"><i class="bi bi-search"></i> Kiểm tra</a>
                            }
                            else
                            {
                                <a href="/Admin/Edit/@item.Id" class="btn btn-warning btn-sm me-1">✏ Sửa</a>
                                <a href="/Admin/Delete/@item.Id" class="btn btn-danger btn-sm" onclick="return confirm('Xóa thật không?')">🗑 Xóa</a>

                                @if (item.Status == "Approved")
                                {
                                    <a href="/Admin/Toggle/@item.Id" class="btn @(item.IsActive ? "btn-outline-secondary" : "btn-outline-success") btn-sm ms-1">
                                        <i class="bi @(item.IsActive ? "bi-eye-slash" : "bi-eye")"></i>
                                    </a>
                                }
                            }
                        </td>
                    </tr>
                }
                @if (!Model.Any())
                {
                    <tr><td colspan="5" class="text-center text-muted py-4">Không có dữ liệu POI nào.</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>