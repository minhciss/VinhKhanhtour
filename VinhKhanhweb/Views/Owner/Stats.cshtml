@{
    Layout = "_OwnerLayout";
    ViewData["Title"] = "Thống kê hoạt động";
}

<div class="d-flex justify-content-between align-items-center mb-2">
    <h3 class="mb-0 text-dark fw-bold">Thống kê hoạt động</h3>
</div>
<div class="alert alert-info border-0 mb-4 py-2 d-flex align-items-center gap-2" style="font-size:13px;">
    <i class="bi bi-info-circle-fill text-info fs-5"></i>
    <span><strong>Lưu ý:</strong> Số liệu dưới đây là dữ liệu <em>minh họa</em>. Hệ thống thống kê thực tế sẽ khả dụng trong phiên bản tiếp theo.</span>
</div>

<div class="row mb-4 g-4">
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-primary text-white">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-white-50 fw-bold mb-1">Tổng Số Điểm (POI)</h6>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalPois</h2>
                </div>
                <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-geo-alt fs-3"></i>
                </div>
            </div>
        </div>
    </div>
    
    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-success text-white">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-white-50 fw-bold mb-1">Lượt Xem Bản Đồ</h6>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalViews</h2>
                </div>
                <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-eye fs-3"></i>
                </div>
            </div>
        </div>
    </div>

    <div class="col-md-4">
        <div class="card border-0 shadow-sm rounded-4 h-100 bg-info text-white">
            <div class="card-body p-4 d-flex align-items-center justify-content-between">
                <div>
                    <h6 class="text-white-50 fw-bold mb-1">Lượt Nghe Audio</h6>
                    <h2 class="mb-0 fw-bold">@ViewBag.TotalAudioPlays</h2>
                </div>
                <div class="bg-white bg-opacity-25 rounded-circle d-flex align-items-center justify-content-center" style="width: 60px; height: 60px;">
                    <i class="bi bi-headphones fs-3"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0 rounded-4">
    <div class="card-header bg-white border-bottom py-3">
        <h5 class="mb-0 text-dark fw-bold"><i class="bi bi-bar-chart me-2 text-primary"></i>Hiệu suất từng điểm đến</h5>
    </div>
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover align-middle mb-0">
                <thead class="table-light">
                    <tr>
                        <th class="ps-4">Tên Điểm Đến (POI)</th>
                        <th>Lượt Xem Cấu Hình</th>
                        <th>Lượt Nghe Audio</th>
                        <th>Trạng thái</th>
                    </tr>
                </thead>
                <tbody>
                    @if (ViewBag.StatsList != null)
                    {
                        foreach (var stat in ViewBag.StatsList)
                        {
                            <tr>
                                <td class="ps-4 fw-bold">@stat.PoiName</td>
                                <td><span class="badge bg-light text-dark border">@stat.Views</span></td>
                                <td><span class="badge bg-light text-dark border">@stat.AudioPlays</span></td>
                                <td>
                                    @if(stat.Status == "Pending")
                                    {
                                        <span class="badge bg-warning text-dark">Chờ duyệt</span>
                                    }
                                    else if(stat.Status == "Approved")
                                    {
                                        <span class="badge bg-success">Đã duyệt</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Khóa</span>
                                    }
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
