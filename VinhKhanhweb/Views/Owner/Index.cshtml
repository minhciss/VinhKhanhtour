@{
    Layout = "_OwnerLayout";
}
@model List<VinhKhanhadmin.Models.Poi>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h3 class="mb-0 text-dark fw-bold">Danh sách Điểm Đến Của Bạn</h3>
    <a href="/Owner/Create" class="btn btn-primary shadow-sm"><i class="bi bi-plus-lg me-1"></i>Đăng ký điểm mới</a>
</div>

<div class="row g-4">
    @foreach(var poi in Model)
    {
        <div class="col-md-6 col-lg-4">
            <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden position-relative">
                @if (poi.Status == "Pending")
                {
                    <div class="position-absolute top-0 end-0 bg-warning text-dark px-3 py-1 rounded-bl-3 fw-bold shadow-sm" style="border-bottom-left-radius: 10px; z-index:10;">
                        <i class="bi bi-hourglass-split me-1"></i> Đang chờ duyệt
                    </div>
                }
                else if (poi.Status == "Rejected")
                {
                    <div class="position-absolute top-0 end-0 bg-danger text-white px-3 py-1 rounded-bl-3 fw-bold shadow-sm" style="border-bottom-left-radius: 10px; z-index:10;">
                        <i class="bi bi-x-circle me-1"></i> Từ chối
                    </div>
                }
                else 
                {
                    <div class="position-absolute top-0 end-0 bg-success text-white px-3 py-1 rounded-bl-3 fw-bold shadow-sm" style="border-bottom-left-radius: 10px; z-index:10;">
                        <i class="bi bi-check-circle me-1"></i> Đã duyệt
                    </div>
                }

                <div style="height: 180px; overflow: hidden; background: #eee;">
                    @if (!string.IsNullOrEmpty(poi.ImageUrl))
                    {
                        <img src="@poi.ImageUrl" class="w-100 h-100" style="object-fit: cover;" />
                    }
                    else
                    {
                        <div class="w-100 h-100 d-flex align-items-center justify-content-center text-muted">
                            <i class="bi bi-images fs-1 border rounded bg-white p-3 shadow-sm"></i>
                        </div>
                    }
                </div>
                
                <div class="card-body">
                    <h5 class="card-title fw-bold text-truncate" title="@poi.Name">@poi.Name</h5>
                    <p class="card-text text-muted small text-truncate"><i class="bi bi-geo-alt me-1"></i>@poi.Address</p>
                    <hr class="text-muted opacity-25">
                    
                    <div class="d-flex justify-content-between align-items-center">
                        <div class="small">
                            @if(poi.Translations?.Any() == true)
                            {
                                <span class="text-success"><i class="bi bi-mic-fill me-1"></i>Đã có audio</span>
                            }
                            else
                            {
                                <span class="text-danger"><i class="bi bi-mic-mute-fill me-1"></i>Chưa có audio</span>
                            }
                        </div>
                        
                        <div class="d-flex gap-1">
                            <button type="button" class="btn btn-outline-dark btn-sm" title="Lấy mã QR" data-bs-toggle="modal" data-bs-target="#qrModal" data-poi-id="@poi.Id" data-poi-name="@poi.Name">
                                <i class="bi bi-qr-code"></i> QR
                            </button>
                            <a href="/Owner/Edit/@poi.Id" class="btn btn-outline-primary btn-sm">
                                <i class="bi bi-pencil-square"></i> Cập nhật
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }

    @if (!Model.Any())
    {
        <div class="col-12">
            <div class="alert alert-info py-5 text-center bg-white border-0 shadow-sm rounded-4">
                <i class="bi bi-shop fs-1 text-primary mb-3 d-block"></i>
                <h5>Bạn chưa đăng ký địa điểm nào.</h5>
                <p class="text-muted">Hãy bắt đầu bằng cách thêm địa điểm kinh doanh, di tích hoặc bảo tàng của bạn.</p>
                <a href="/Owner/Create" class="btn btn-primary px-4"><i class="bi bi-plus-lg me-1"></i>Thêm địa điểm đầu tiên</a>
            </div>
        </div>
    }
</div>

<!-- QR Code Modal -->
<div class="modal fade" id="qrModal" tabindex="-1" aria-labelledby="qrModalLabel" aria-hidden="true">
  <div class="modal-dialog modal-dialog-centered modal-sm">
    <div class="modal-content rounded-4 border-0 shadow">
      <div class="modal-header border-bottom-0 pb-0">
        <h5 class="modal-title fw-bold" id="qrModalLabel">Mã QR</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
      </div>
      <div class="modal-body text-center pt-2">
        <p class="text-muted small mb-3" id="qrPoiName"></p>
        <div class="bg-light p-3 rounded-3 d-inline-block border mb-3">
            <img id="qrImage" src="" alt="QR Code" class="img-fluid" style="width: 200px; height: 200px; object-fit: contain;" />
        </div>
        <div>
            <a id="qrDownloadBtn" href="#" download="qrcode.png" class="btn btn-primary w-100 fw-bold">
                <i class="bi bi-download me-1"></i> Tải ảnh xuống
            </a>
        </div>
      </div>
    </div>
  </div>
</div>

@section Scripts {
    <script>
        const qrModal = document.getElementById('qrModal');
        if (qrModal) {
            qrModal.addEventListener('show.bs.modal', event => {
                // Nút vừa click
                const button = event.relatedTarget;
                // Trích xuất thông tin
                const poiId = button.getAttribute('data-poi-id');
                const poiName = button.getAttribute('data-poi-name');
                
                // Cập nhật Modal
                const modalTitle = qrModal.querySelector('#qrPoiName');
                const qrImage = qrModal.querySelector('#qrImage');
                const qrDownload = qrModal.querySelector('#qrDownloadBtn');

                modalTitle.textContent = poiName;
                
                const imageUrl = '/QRCode/Image?poiId=' + poiId;
                qrImage.src = imageUrl;
                qrDownload.href = imageUrl;
            });
        }
    </script>
}
