<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="VinhKhanhTour.Pages.MapPage"
             xmlns:local="clr-namespace:VinhKhanhTour.MarkupExtensions"
             Title="{local:Translate 'Bản Đồ Phố Vĩnh Khánh'}"
             Shell.NavBarIsVisible="False">

    <Grid x:Name="MapContainer">
        <!-- Map Control will be loaded dynamically on supported platforms -->

        <!-- Top Overlay: GPS Status -->
        <Border Margin="{OnIdiom Phone='15,45,15,0', Tablet='30,60,30,0', Desktop='40,40,40,0'}" 
                Padding="15,10"
                HorizontalOptions="Center" 
                VerticalOptions="Start"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                StrokeShape="RoundRectangle 24"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Opacity="0.15" Offset="0,4" Radius="12" />
            </Border.Shadow>
            <HorizontalStackLayout Spacing="10">
                <Border StrokeShape="RoundRectangle 5" 
                        WidthRequest="10" HeightRequest="10" 
                        BackgroundColor="#27AE60" 
                        StrokeThickness="0"
                        VerticalOptions="Center" />
                <Label x:Name="DebugLabel" 
                       Text="{local:Translate 'Đang tìm kiếm vệ tinh GPS...'}" 
                       FontSize="{OnIdiom Phone=13, Tablet=15, Desktop=15}" 
                       FontAttributes="Bold" 
                       VerticalOptions="Center" />
            </HorizontalStackLayout>
        </Border>

        <!-- Floating Action Buttons -->
        <VerticalStackLayout VerticalOptions="Start" HorizontalOptions="End" Margin="{OnIdiom Phone='0,50,16,0', Tablet='0,80,30,0', Desktop='0,80,40,0'}" Spacing="10">
            <Button x:Name="MyLocationButton" Text="📍" FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=24}"
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" 
                    TextColor="{StaticResource Primary}" 
                    WidthRequest="{OnIdiom Phone=48, Tablet=56, Desktop=56}" HeightRequest="{OnIdiom Phone=48, Tablet=56, Desktop=56}" CornerRadius="{OnIdiom Phone=24, Tablet=28, Desktop=28}" Padding="0" 
                    Clicked="OnMyLocationClicked">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,3" Radius="8" Opacity="0.15"/>
                </Button.Shadow>
            </Button>
            <Button x:Name="ZoomInButton" Text="＋" FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=24}" 
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" 
                    TextColor="{StaticResource Primary}" 
                    WidthRequest="{OnIdiom Phone=48, Tablet=56, Desktop=56}" HeightRequest="{OnIdiom Phone=48, Tablet=56, Desktop=56}" CornerRadius="{OnIdiom Phone=24, Tablet=28, Desktop=28}" Padding="0" 
                    Clicked="OnZoomInClicked">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,3" Radius="8" Opacity="0.15"/>
                </Button.Shadow>
            </Button>
            <Button x:Name="ZoomOutButton" Text="－" FontSize="{OnIdiom Phone=20, Tablet=24, Desktop=24}" 
                    BackgroundColor="{AppThemeBinding Light=White, Dark=#2A2A2A}" 
                    TextColor="{StaticResource Primary}" 
                    WidthRequest="{OnIdiom Phone=48, Tablet=56, Desktop=56}" HeightRequest="{OnIdiom Phone=48, Tablet=56, Desktop=56}" CornerRadius="{OnIdiom Phone=24, Tablet=28, Desktop=28}" Padding="0" 
                    Clicked="OnZoomOutClicked">
                <Button.Shadow>
                    <Shadow Brush="Black" Offset="0,3" Radius="8" Opacity="0.15"/>
                </Button.Shadow>
            </Button>
        </VerticalStackLayout>

        <!-- Bottom Map Overlay (Now Playing) -->
        <Border VerticalOptions="End" Margin="{OnIdiom Phone='12,0,12,24', Tablet='40,0,40,40', Desktop='80,0,80,40'}" Padding="0"
                StrokeShape="RoundRectangle 20" 
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                StrokeThickness="0"
                MaximumWidthRequest="{OnIdiom Phone=600, Tablet=800, Desktop=800}"
                HorizontalOptions="{OnIdiom Phone=Fill, Tablet=Center, Desktop=Center}">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,8" Radius="24" Opacity="0.2"/>
            </Border.Shadow>

            <Grid RowDefinitions="Auto, Auto" ColumnDefinitions="*, Auto" Padding="{OnIdiom Phone='20,16', Tablet='24,20', Desktop='24,20'}">
                <!-- POI Info & Distance -->
                <VerticalStackLayout Grid.Column="0" Spacing="4" Margin="0,0,16,0">
                    <Label Text="{local:Translate 'BẠN ĐANG Ở GẦN'}" FontSize="10" FontAttributes="Bold" TextColor="{StaticResource Primary}" CharacterSpacing="1" />
                    <Label x:Name="PoiNameLabel" Text="{local:Translate 'Chọn một điểm trên map'}" FontSize="{OnIdiom Phone=18, Tablet=22, Desktop=24}" FontAttributes="Bold" MaxLines="2" LineBreakMode="WordWrap"/>
                    <Label x:Name="DistanceLabel" Text="Khoảng cách: -- m" FontSize="{OnIdiom Phone=13, Tablet=15, Desktop=15}" Opacity="0.6"/>
                </VerticalStackLayout>

                <!-- Audio Controls -->
                <HorizontalStackLayout Grid.Row="{OnIdiom Phone=1, Tablet=0, Desktop=0}" Grid.Column="{OnIdiom Phone=0, Tablet=1, Desktop=1}" Grid.ColumnSpan="{OnIdiom Phone=2, Tablet=1, Desktop=1}" 
                                       HorizontalOptions="Center" VerticalOptions="Center" Spacing="{OnIdiom Phone=24, Tablet=16, Desktop=16}" Margin="{OnIdiom Phone='0,14,0,0', Tablet='0,0,0,0', Desktop='0,0,0,0'}">
                    <Button Text="⏮" FontSize="22" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" 
                            WidthRequest="48" HeightRequest="48" Clicked="OnPrevPoiClicked"/>
                    <Button Text="||" FontAttributes="Bold" x:Name="PlayPauseButton" FontSize="20" 
                            BackgroundColor="{StaticResource Primary}" TextColor="White" 
                            WidthRequest="56" HeightRequest="56" CornerRadius="28" Padding="0" 
                            Clicked="OnPlayPauseClicked">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Offset="0,4" Radius="12" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>
                    <Button Text="⏭" FontSize="22" BackgroundColor="Transparent" TextColor="{StaticResource Primary}" 
                            WidthRequest="48" HeightRequest="48" Clicked="OnNextPoiClicked"/>
                </HorizontalStackLayout>
            </Grid>
        </Border>

        <!-- 🎮 Simulation Mode Panel -->
        <Border x:Name="SimPanel"
                HorizontalOptions="Start"
                VerticalOptions="Start"
                Margin="{OnIdiom Phone='12,120,0,0', Tablet='30,140,0,0', Desktop='40,140,0,0'}"
                Padding="12"
                StrokeShape="RoundRectangle 16"
                BackgroundColor="{AppThemeBinding Light=White, Dark=#1E1E1E}"
                StrokeThickness="0">
            <Border.Shadow>
                <Shadow Brush="Black" Offset="0,4" Radius="12" Opacity="0.2"/>
            </Border.Shadow>
            <VerticalStackLayout Spacing="8">

                <!-- Toggle Button -->
                <Button x:Name="SimToggleButton"
                        Text="🎮 Giả lập"
                        FontSize="13"
                        FontAttributes="Bold"
                        BackgroundColor="#6C757D"
                        TextColor="White"
                        CornerRadius="10"
                        Padding="12,6"
                        HeightRequest="36"
                        Clicked="OnSimToggleClicked"/>

                <!-- D-Pad (chỉ hiện khi đang giả lập) -->
                <Grid x:Name="DPadGrid" IsVisible="False"
                      RowDefinitions="44,44,44"
                      ColumnDefinitions="44,44,44"
                      RowSpacing="4" ColumnSpacing="4">

                    <!-- ▲ Bắc -->
                    <Button Grid.Row="0" Grid.Column="1" Text="▲" FontSize="20"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="10" Padding="0"
                            Clicked="OnSimNorthClicked">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Offset="0,2" Radius="6" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>

                    <!-- ◄ Tây -->
                    <Button Grid.Row="1" Grid.Column="0" Text="◄" FontSize="20"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="10" Padding="0"
                            Clicked="OnSimWestClicked">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Offset="0,2" Radius="6" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>

                    <!-- Tâm -->
                    <Border Grid.Row="1" Grid.Column="1"
                            StrokeShape="RoundRectangle 10" StrokeThickness="0"
                            BackgroundColor="{AppThemeBinding Light=#F5F5F5, Dark=#2A2A2A}">
                        <Label Text="⊙" FontSize="20"
                               HorizontalOptions="Center" VerticalOptions="Center"
                               TextColor="{StaticResource Primary}"/>
                    </Border>

                    <!-- ► Đông -->
                    <Button Grid.Row="1" Grid.Column="2" Text="►" FontSize="20"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="10" Padding="0"
                            Clicked="OnSimEastClicked">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Offset="0,2" Radius="6" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>

                    <!-- ▼ Nam -->
                    <Button Grid.Row="2" Grid.Column="1" Text="▼" FontSize="20"
                            BackgroundColor="{StaticResource Primary}" TextColor="White"
                            CornerRadius="10" Padding="0"
                            Clicked="OnSimSouthClicked">
                        <Button.Shadow>
                            <Shadow Brush="{StaticResource Primary}" Offset="0,2" Radius="6" Opacity="0.3"/>
                        </Button.Shadow>
                    </Button>
                </Grid>

                <!-- Tọa độ giả lập -->
                <Label x:Name="SimCoordLabel"
                       Text="--"
                       FontSize="10"
                       HorizontalOptions="Center"
                       IsVisible="False"
                       TextColor="{StaticResource Primary}"
                       FontAttributes="Bold"/>
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
